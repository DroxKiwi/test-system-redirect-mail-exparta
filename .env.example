# Copiez ce fichier en `.env` à la racine et renseignez les valeurs.
# Ne versionnez jamais `.env` (déjà ignoré par git).

# --- Base de données (obligatoire) ---
# Ex. postgresql://user:motdepasse@localhost:5432/nom_base
DATABASE_URL=

# --- Réception SMTP (passerelle → POST /api/inbound/mail) ---
# Même valeur que celle configurée côté serveur / relais qui envoie le MIME brut.
INBOUND_SECRET=

# --- Premier compte (/setup) ---
# Jeton secret à fournir une fois pour créer l’administrateur initial.
# À retirer ou laisser vide une fois le setup terminé (selon votre politique).
FIRST_SETUP_TOKEN=

# --- URL publique de l’app (OAuth, textes d’aide) ---
# En prod derrière un domaine : https://mail.exemple.fr (sans slash final).
# Sinon Next déduit depuis les en-têtes du reverse proxy ; en dernier recours : window du navigateur.
BASE_URL=

# --- Worker (synchro cloud + règles) ---
# Obligatoire si vous utilisez `linker/robot.py` ou tout client qui appelle
# POST /api/internal/worker/trigger/tick — même valeur côté Next et côté robot.
WORKER_TRIGGER_SECRET=

# --- Optionnel : télémétrie Next.js ---
# NEXT_TELEMETRY_DISABLED=1
