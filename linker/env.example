# Le robot charge automatiquement le `.env` à la racine du dépôt (celui de Next).
# Ajoute-y les clés ci-dessous si tu ne les as pas déjà ; pas besoin de fichier séparé dans linker/.

# Obligatoire pour les routes /api/internal/worker/* (même valeur côté Next)
# WORKER_TRIGGER_SECRET=au-moins-16-caracteres

# URL de l’app (défaut du robot si absent : http://localhost:3000).
# En prod : même origine que BASE_URL côté Next (ex. https://mail.exemple.fr).
# NEXT_APP_BASE_URL=http://localhost:3000

# INTERVAL_SECONDS=60
# TRIGGER_PATH=/api/internal/worker/trigger/tick
# PROCESS_LIMIT=40
